# ---------------------------------------------------------------------------
# Runtime data — never commit images or logs
# ---------------------------------------------------------------------------

# Input images dropped by users
data/input/*
!data/input/.gitkeep

# Processed images (moved here after ALPR)
data/processed/*
!data/processed/.gitkeep

# Daily CSV log files
data/logs/*
!data/logs/.gitkeep

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------

# Never commit environment variable files — they may contain API keys or passwords
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Development tooling
# ---------------------------------------------------------------------------

# pytest cache
.pytest_cache/
.cache/

# mypy
.mypy_cache/

# ruff / flake8
.ruff_cache/

# Coverage reports
htmlcov/
.coverage
coverage.xml

# ---------------------------------------------------------------------------
# Editors and OS
# ---------------------------------------------------------------------------

# VS Code (keep .vscode/extensions.json for recommended extensions if desired,
# but ignore personal settings and launch configs)
.vscode/settings.json
.vscode/launch.json

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# JetBrains IDEs
.idea/
